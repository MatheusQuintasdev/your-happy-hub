import { serve } from "https://deno.land/std@0.168.0/http/server.ts"
import { createClient } from "https://esm.sh/@supabase/supabase-js@2.7.1"

const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type',
}

serve(async (req) => {
  if (req.method === 'OPTIONS') {
    return new Response('ok', { headers: corsHeaders })
  }

  try {
    const authHeader = req.headers.get('Authorization')
    if (!authHeader) throw new Error('Missing Authorization header')

    const supabaseClient = createClient(
      Deno.env.get('SUPABASE_URL') ?? '',
      Deno.env.get('SUPABASE_SERVICE_ROLE_KEY') ?? ''
    )

    // Validate the user from the token using the user's client
    const userClient = createClient(
      Deno.env.get('SUPABASE_URL') ?? '',
      Deno.env.get('SUPABASE_ANON_KEY') ?? '',
      { global: { headers: { Authorization: authHeader } } }
    )
    
    const { data: { user }, error: authError } = await userClient.auth.getUser()
    if (authError || !user) {
      console.error('Auth Error:', authError)
      throw new Error('Unauthorized')
    }

    const { diagnosticId, mode = 'full' } = await req.json()
    if (!diagnosticId) throw new Error('Missing diagnosticId')

    console.log(`Analyzing diagnostic ${diagnosticId} for user ${user.id}`)

    // Fetch diagnostic using service role client to ensure we can read it
    const { data: diagnostic, error: diagError } = await supabaseClient
      .from('diagnostics')
      .select('*')
      .eq('id', diagnosticId)
      .single()

    if (diagError || !diagnostic) {
      console.error('Diagnostic error:', diagError)
      throw new Error('Diagnostic not found')
    }

    // AI logic via Lovable AI Gateway
    const gatewayResponse = await fetch('https://api.lovable.ai/v1/chat/completions', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${Deno.env.get('LOVABLE_API_KEY')}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        model: 'gemini-1.5-flash',
        messages: [
          {
            role: 'system',
            content: `Você é um Consultor Sênior de Marketing Digital e Especialista em Crescimento (Growth Specialist).
            Sua missão é transformar dados de diagnóstico em uma estratégia de elite para pequenas e médias empresas.
            Não seja genérico. Cada recomendação deve ser profunda, estratégica e personalizada.
            Analise sob 4 pilares: Autoridade, Conversão, Credibilidade e Presença Digital.
            Retorne SEMPRE um JSON válido.`
          },
          {
            role: 'user',
            content: `Realize um DIAGNÓSTICO EXECUTIVO completo para a empresa "${diagnostic.company_name}" (${diagnostic.industry || 'Geral'}).
            Dados do Diagnóstico: ${JSON.stringify(diagnostic.responses || diagnostic.category_scores)}
            Score Atual: ${diagnostic.score}
            
            Estrutura do JSON de resposta:
            {
              "executive_summary": "Resumo de alto impacto estilo consultoria sênior. Identifique o problema raiz e a oportunidade imediata.",
              "growth_plan": {
                "week1": [{"title": "...", "description": "...", "difficulty": "Fácil", "impact": "Alto", "time": "20min"}],
                "week2": [],
                "week3": [],
                "week4": []
              },
              "lost_opportunities": [
                {
                  "category": "Google Meu Negócio | Instagram | Site | WhatsApp | SEO | Avaliações",
                  "situation": "...",
                  "impact": "...",
                  "consequence": "...",
                  "solution": "...",
                  "priority": "Alta"
                }
              ],
              "bottlenecks": [
                {"problem": "...", "impact": "...", "order": 1}
              ],
              "priorities": [
                {"action": "...", "impact": "Alto", "difficulty": "Baixa", "time": "2h", "gain": "..."}
              ],
              "scores": {
                "general": ${diagnostic.score},
                "authority": 0,
                "conversion": 0,
                "credibility": 0,
                "presence": 0
              },
              "simulation": {
                "current_score": ${diagnostic.score},
                "projected_score": 0,
                "reasoning": "..."
              },
              "content_suggestions": {
                "instagram_posts": [{"caption": "...", "image_idea": "...", "cta": "..."}],
                "gmb_posts": [],
                "review_requests": []
              }
            }`
          }
        ],
        response_format: { type: "json_object" }
      }),
    })

    if (!gatewayResponse.ok) {
      const errorText = await gatewayResponse.text()
      console.error('AI Gateway Error:', errorText)
      throw new Error('AI Gateway communication failed')
    }

    const aiResult = await gatewayResponse.json()
    const content = JSON.parse(aiResult.choices[0].message.content)

    // Save to database
    const { error: saveError } = await supabaseClient
      .from('ai_insights')
      .upsert({
        diagnostic_id: diagnosticId,
        user_id: user.id,
        executive_summary: content.executive_summary,
        growth_plan: content.growth_plan,
        lost_opportunities: content.lost_opportunities,
        bottlenecks: content.bottlenecks,
        priorities: content.priorities,
        simulations: content.simulation || content.simulations,
        scores: content.scores,
        content_suggestions: content.content_suggestions,
        updated_at: new Date().toISOString()
      })

    if (saveError) {
      console.error('Save AI Insights Error:', saveError)
      throw saveError
    }

    // Auto-generate tasks for the first week
    if (content.growth_plan?.week1) {
      const firstWeekTasks = content.growth_plan.week1.map((t: any) => ({
        user_id: user.id,
        diagnostic_id: diagnosticId,
        title: t.title,
        description: t.description,
        difficulty: t.difficulty,
        impact: t.impact,
        estimated_time: t.time
      }))

      const { error: taskError } = await supabaseClient.from('user_tasks').insert(firstWeekTasks)
      if (taskError) console.error('Task generation error:', taskError)
    }

    return new Response(JSON.stringify(content), {
      headers: { ...corsHeaders, 'Content-Type': 'application/json' },
    })

  } catch (error) {
    console.error(`AI Analysis Error: ${error.message}`)
    
    const fallbackContent = {
      executive_summary: "Geramos um plano de contingência estratégico baseado nos dados do seu diagnóstico.",
      growth_plan: {
        week1: [{title: "Otimização Imediata", description: "Foque em atualizar suas informações básicas e solicitar avaliações.", difficulty: "Fácil", impact: "Alto", time: "30min"}],
        week2: [], week3: [], week4: []
      },
      lost_opportunities: [],
      bottlenecks: [{problem: "Limitação técnica temporária", impact: "Impede análise profunda", order: 1}],
      priorities: [{action: "Re-executar análise", impact: "Alto", difficulty: "Baixa", time: "1min", gain: "Insights completos"}],
      scores: { general: 50, authority: 50, conversion: 50, credibility: 50, presence: 50 },
      simulation: { current_score: 50, projected_score: 75, reasoning: "Melhoria baseada em ações recomendadas." },
      content_suggestions: { instagram_posts: [], gmb_posts: [], review_requests: [] }
    }

    return new Response(JSON.stringify(fallbackContent), {
      status: 200,
      headers: { ...corsHeaders, 'Content-Type': 'application/json' },
    })
  }
})

